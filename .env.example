# Django
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Production uses MySQL (see production.py / .env DB_* vars).
# Local development uses SQLite automatically via config.settings.development
DB_ENGINE=django.db.backends.mysql
DB_NAME=email_platform
DB_USER=email_platform_user
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=3306

# Redis
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email (development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Media / Static
MEDIA_URL=/media/
STATIC_URL=/static/

# Logging
LOG_LEVEL=INFO

# Frontend / Email
FRONTEND_URL=http://localhost:5173
# Public URL for open tracking in emails (Gmail must reach this — not localhost)
TRACKING_PUBLIC_BASE_URL=http://127.0.0.1:8000
DEFAULT_FROM_EMAIL=noreply@emailplatform.local
EMAIL_VERIFICATION_TOKEN_HOURS=24
PASSWORD_RESET_TOKEN_HOURS=2

# Gunicorn (production)
GUNICORN_BIND=127.0.0.1:8000
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
