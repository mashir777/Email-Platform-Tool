# Django
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database — Django SQLite (file: backend/db.sqlite3)

# Redis
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# After Vercel deploy add: ,https://your-app.vercel.app
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email — Gmail SMTP (real inbox)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=your-gmail@gmail.com
EMAIL_TIMEOUT=30

# Media / Static
MEDIA_URL=/media/
STATIC_URL=/static/

# Logging
LOG_LEVEL=INFO

# Reacher
REACHER_BACKEND_URL=http://127.0.0.1:8080
REACHER_API_KEY=
REACHER_REQUEST_TIMEOUT=120
REACHER_BULK_TIMEOUT=3600

# Frontend URL used inside verification emails
# Local:
FRONTEND_URL=http://localhost:5173
# Production (Vercel):
# FRONTEND_URL=https://your-app.vercel.app
TRACKING_PUBLIC_BASE_URL=http://127.0.0.1:8000
# Same-domain open tracking (no tunnel). Upload deployment/tracking-proxy/t to
# https://YOURDOMAIN.com/t/ ; TRACKING_PROXY_SECRET must equal config.php shared_secret.
TRACKING_PROXY_BASE_URL=
TRACKING_PROXY_SECRET=
EMAIL_VERIFICATION_TOKEN_HOURS=24
PASSWORD_RESET_TOKEN_HOURS=2

# Gunicorn (production)
GUNICORN_BIND=127.0.0.1:8000
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120

# --- Vercel deploy (set these in Vercel dashboard only, not in local .env) ---
# DJANGO_SETTINGS_MODULE=config.settings.vercel
# DJANGO_ALLOWED_HOSTS=.vercel.app
