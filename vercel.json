{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite",
      "rewrites": [
        { "source": "/((?!assets/).*)", "destination": "/index.html" }
      ]
    },
    "backend": {
      "root": "backend",
      "framework": "django",
      "installCommand": "pip install -r requirements-vercel.txt",
      "buildCommand": "python manage.py migrate --noinput"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": { "service": "backend" } },
    { "source": "/admin/(.*)", "destination": { "service": "backend" } },
    { "source": "/t/(.*)", "destination": { "service": "backend" } },
    { "source": "/(.*)", "destination": { "service": "frontend" } }
  ]
}
