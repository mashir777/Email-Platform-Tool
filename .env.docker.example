# Copy to repo root as `.env` on the EC2 server:
#   cp .env.docker.example .env
# Then edit values below.

# --- Docker / HTTP ---
HTTP_PORT=80

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
DJANGO_DEBUG=False
# Your EC2 public IP and/or domain (comma-separated)
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com,YOUR_EC2_PUBLIC_IP

# Set True only after HTTPS (nginx/certbot) is in front
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0

# --- Postgres (Docker service `db`) ---
POSTGRES_DB=email_platform
POSTGRES_USER=email_platform
POSTGRES_PASSWORD=replace-with-strong-db-password
# DATABASE_URL is set automatically by docker-compose — do not set REDIS host to 127.0.0.1

# --- Redis / Celery (hosts are Docker service names) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- CORS / CSRF (same-origin SPA via nginx — still list your public origins) ---
CORS_ALLOWED_ORIGINS=http://your-domain.com,https://your-domain.com,http://YOUR_EC2_PUBLIC_IP
CSRF_TRUSTED_ORIGINS=http://your-domain.com,https://your-domain.com,http://YOUR_EC2_PUBLIC_IP

# --- Public URLs ---
FRONTEND_URL=http://your-domain.com
TRACKING_PUBLIC_BASE_URL=http://your-domain.com
TRACKING_PROXY_BASE_URL=
TRACKING_PROXY_SECRET=

# --- Email (Gmail SMTP example) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=your-gmail@gmail.com
EMAIL_TIMEOUT=30
EMAIL_VERIFICATION_TOKEN_HOURS=24
PASSWORD_RESET_TOKEN_HOURS=2

# --- Media / Static ---
MEDIA_URL=/media/
STATIC_URL=/static/

# --- Logging / Gunicorn ---
LOG_LEVEL=INFO
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120

# --- Reacher (enable with: ./scripts/docker-up.sh --profile reacher) ---
REACHER_BACKEND_URL=http://reacher:8080
REACHER_API_KEY=
REACHER_REQUEST_TIMEOUT=120
REACHER_BULK_TIMEOUT=3600
