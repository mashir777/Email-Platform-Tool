# Serve this /t/ folder DIRECTLY (static + PHP) instead of routing it through the
# datrixworld.com Django app (Phusion Passenger). Without this, Django catches
# /t/... and returns 404, so the tracking pixel never records opens.

# Disable the Python/Django (Passenger) app for this directory and below.
PassengerEnabled off

# Do not let Passenger/mod_rewrite hijack these URLs.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^ - [L]
</IfModule>

# Make sure PHP runs and plain files are served as-is.
Options -MultiViews +ExecCGI
DirectoryIndex ping.txt

<FilesMatch "\.php$">
    SetHandler application/x-httpd-php
</FilesMatch>
