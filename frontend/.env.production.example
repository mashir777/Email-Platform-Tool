# Used by `vercel build` / production preview locally
# Set the same values in Vercel → Project → Settings → Environment Variables

# Public Django API (required on Vercel — localhost will NOT work in users' browsers)
VITE_API_BASE_URL=https://YOUR_PUBLIC_BACKEND_URL

# Tracking base (optional)
VITE_TRACKING_PUBLIC_BASE_URL=https://datrixworld.com
