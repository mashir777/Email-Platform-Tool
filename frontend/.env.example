# Development (Vite proxy) — leave empty
# VITE_API_BASE_URL=

# Production / Vercel — public Django API URL (no trailing slash)
# Example: https://api.yourdomain.com   or   https://xxxx.trycloudflare.com
VITE_API_BASE_URL=https://YOUR_PUBLIC_BACKEND_URL

# Public backend URL for email open tracking (Gmail must reach this)
VITE_TRACKING_PUBLIC_BASE_URL=https://datrixworld.com
