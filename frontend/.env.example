# Use empty value in development to route through Vite proxy (/api → Django)
VITE_API_BASE_URL=

# Public backend URL for email open tracking (Gmail must reach this)
# Example: http://YOUR_PUBLIC_IP:8000  or  https://xxxx.ngrok-free.app
# Leave empty to auto-use http://<your-pc-hostname>:8000 when sending
VITE_TRACKING_PUBLIC_BASE_URL=
